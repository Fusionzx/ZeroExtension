{
  "manifest_version": 3,
  "name": "HaxBall Zero",
  "version": "2.0.1",
  "description": "Extensão oficial do HaxBall Zero",
  "content_scripts": [
    {
      "matches": [
        "*://www.haxball.com/*",
        "*://haxball.com/*",
        "*://*.haxball.com/*",
        "*://html5.haxball.com/*"
      ],
      "js": [
        "browser-loader.js",
        "config.js",
        "core.js",
        "captcha-quota-hint.js",
        "hxd-sync-input-tolerance.js",
        "welcome.js",
        "styles.js",
        "themes.js",
        "hxd-performance.js",
        "inputboost.js",
        "header.js",
        "settings.js",
        "stretched.js",
        "discord.js",
        "verified.js",
        "vip.js",
        "roomlist.js",
        "scoreboard.js",
        "smart-extrapolation.js",
        "split-extrapolation.js",
        "jerseykit.js",
        "chathistory.js",
        "chatlinks.js",
        "hideui.js",
        "quickavatar.js",
        "hosttoken.js",
        "leaveroom.js",
        "shortcuts.js",
        "chat-expand.js",
        "translate.js",
        "goal-celebration.js",
        "ads.js",
        "security.js",
        "background.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "interceptor.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "runtime.js",
        "game-min-original.js",
        "*.js",
        "*.html",
        "icons/*"
      ],
      "matches": [
        "*://*.haxball.com/*",
        "*://haxball.com/*"
      ]
    }
  ],
  "permissions": [
    "declarativeNetRequestWithHostAccess",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "*://www.haxball.com/*",
    "*://haxball.com/*",
    "*://*.haxball.com/*",
    "*://html5.haxball.com/*",
    "*://localhost/*",
    "*://127.0.0.1/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "haxball_runtime_redirect",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
